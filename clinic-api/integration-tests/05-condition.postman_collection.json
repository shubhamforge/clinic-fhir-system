{
  "info": {
    "name": "05 — Condition",
    "description": "ConditionController — POST /api/conditions, GET /api/conditions/{id}, GET /api/conditions?patientId.\n\nDependency: Patient (created in Setup). No practitioner needed.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "patientId",    "value": "" },
    { "key": "conditionId",  "value": "" },
    { "key": "conditionId2", "value": "" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const token = pm.environment.get('BEARER_TOKEN');",
          "if (token) {",
          "  pm.request.headers.add({ key: 'Authorization', value: 'Bearer ' + token });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Setup — Create Patient",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/patients",
          "host": ["{{baseUrl}}"],
          "path": ["api", "patients"]
        },
        "body": {
          "mode": "raw",
          "options": { "raw": { "language": "json" } },
          "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"Condition\",\n  \"dateOfBirth\": \"1965-03-12\",\n  \"gender\": \"male\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.collectionVariables.set('patientId', pm.response.json().id);"
            ]
          }
        }
      ]
    },
    {
      "name": "POST Condition — Active",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/conditions",
          "host": ["{{baseUrl}}"],
          "path": ["api", "conditions"]
        },
        "body": {
          "mode": "raw",
          "options": { "raw": { "language": "json" } },
          "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"code\": \"59621000\",\n  \"display\": \"Essential hypertension\",\n  \"clinicalStatus\": \"active\",\n  \"onsetDate\": \"2024-01-15\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "",
              "const body = pm.response.json();",
              "pm.test('resourceType is Condition', () => pm.expect(body.resourceType).to.eql('Condition'));",
              "pm.test('Has id', () => pm.expect(body.id).to.be.a('string').and.not.empty);",
              "pm.test('clinicalStatus is active', () => {",
              "  pm.expect(body.clinicalStatus.coding[0].code).to.eql('active');",
              "});",
              "pm.test('Subject references patient', () => {",
              "  pm.expect(body.subject.reference).to.include(pm.collectionVariables.get('patientId'));",
              "});",
              "pm.collectionVariables.set('conditionId', body.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "POST Condition — Resolved",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/conditions",
          "host": ["{{baseUrl}}"],
          "path": ["api", "conditions"]
        },
        "body": {
          "mode": "raw",
          "options": { "raw": { "language": "json" } },
          "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"code\": \"271807003\",\n  \"display\": \"Cholelithiasis\",\n  \"clinicalStatus\": \"resolved\",\n  \"onsetDate\": \"2025-10-01\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "",
              "const body = pm.response.json();",
              "pm.test('clinicalStatus is resolved', () => {",
              "  pm.expect(body.clinicalStatus.coding[0].code).to.eql('resolved');",
              "});",
              "pm.collectionVariables.set('conditionId2', body.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "GET Condition by ID",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/conditions/{{conditionId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "conditions", "{{conditionId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "",
              "const body = pm.response.json();",
              "pm.test('ID matches', () => pm.expect(body.id).to.eql(pm.collectionVariables.get('conditionId')));",
              "pm.test('clinicalStatus is active', () => pm.expect(body.clinicalStatus.coding[0].code).to.eql('active'));"
            ]
          }
        }
      ]
    },
    {
      "name": "LIST Conditions for Patient",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/conditions?patientId={{patientId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "conditions"],
          "query": [{ "key": "patientId", "value": "{{patientId}}" }]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "",
              "const body = pm.response.json();",
              "pm.test('resourceType is Bundle', () => pm.expect(body.resourceType).to.eql('Bundle'));",
              "pm.test('Two conditions returned', () => pm.expect(body.entry.length).to.eql(2));",
              "",
              "const ids = body.entry.map(e => e.resource.id);",
              "pm.test('Both condition IDs present', () => {",
              "  pm.expect(ids).to.include(pm.collectionVariables.get('conditionId'));",
              "  pm.expect(ids).to.include(pm.collectionVariables.get('conditionId2'));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Error — POST Condition Missing code",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/conditions",
          "host": ["{{baseUrl}}"],
          "path": ["api", "conditions"]
        },
        "body": {
          "mode": "raw",
          "options": { "raw": { "language": "json" } },
          "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"display\": \"Essential hypertension\",\n  \"clinicalStatus\": \"active\",\n  \"onsetDate\": \"2024-01-15\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 400', () => pm.response.to.have.status(400));"
            ]
          }
        }
      ]
    },
    {
      "name": "Error — GET Condition Not Found",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/conditions/nonexistent-condition-99999",
          "host": ["{{baseUrl}}"],
          "path": ["api", "conditions", "nonexistent-condition-99999"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 404', () => pm.response.to.have.status(404));",
              "",
              "const body = pm.response.json();",
              "pm.test('Error shape', () => {",
              "  pm.expect(body.status).to.eql(404);",
              "  pm.expect(body.message).to.be.a('string').and.not.empty;",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Teardown — Cascade Delete Patient",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const pid = pm.collectionVariables.get('patientId');",
              "if (!pid) throw new Error('patientId is empty — teardown aborted');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Patient deleted', () => pm.expect(pm.response.code).to.be.oneOf([200, 204]));"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{fhirUrl}}/Patient/{{patientId}}?_cascade=delete",
          "host": ["{{fhirUrl}}"],
          "path": ["Patient", "{{patientId}}"],
          "query": [{ "key": "_cascade", "value": "delete" }]
        }
      }
    },
    {
      "name": "Teardown — Verify Patient Deleted",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/patients/{{patientId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "patients", "{{patientId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Patient gone (404 or 410)', () => pm.expect(pm.response.code).to.be.oneOf([404, 410]));"
            ]
          }
        }
      ]
    }
  ]
}
