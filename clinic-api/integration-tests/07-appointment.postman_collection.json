{
  "info": {
    "name": "07 — Appointment",
    "description": "AppointmentController — POST /api/appointments, GET /api/appointments?patientId.\n\nDependencies: Practitioner + Patient. Tests booked (future) and fulfilled (past) appointments.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "practitionerId",  "value": "" },
    { "key": "patientId",       "value": "" },
    { "key": "appointmentId",   "value": "" },
    { "key": "appointmentId2",  "value": "" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const token = pm.environment.get('BEARER_TOKEN');",
          "if (token) {",
          "  pm.request.headers.add({ key: 'Authorization', value: 'Bearer ' + token });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Setup — Create Practitioner",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/practitioners",
          "host": ["{{baseUrl}}"],
          "path": ["api", "practitioners"]
        },
        "body": {
          "mode": "raw",
          "options": { "raw": { "language": "json" } },
          "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"Practitioner\",\n  \"specialty\": \"General Practice\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.collectionVariables.set('practitionerId', pm.response.json().id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Setup — Create Patient",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/patients",
          "host": ["{{baseUrl}}"],
          "path": ["api", "patients"]
        },
        "body": {
          "mode": "raw",
          "options": { "raw": { "language": "json" } },
          "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"Appointment\",\n  \"dateOfBirth\": \"1990-07-22\",\n  \"gender\": \"female\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.collectionVariables.set('patientId', pm.response.json().id);"
            ]
          }
        }
      ]
    },
    {
      "name": "POST Appointment — Future (booked)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/appointments",
          "host": ["{{baseUrl}}"],
          "path": ["api", "appointments"]
        },
        "body": {
          "mode": "raw",
          "options": { "raw": { "language": "json" } },
          "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"practitionerId\": \"{{practitionerId}}\",\n  \"start\": \"2026-07-15T09:00:00\",\n  \"end\": \"2026-07-15T09:30:00\",\n  \"description\": \"Annual review\",\n  \"status\": \"booked\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "",
              "const body = pm.response.json();",
              "pm.test('resourceType is Appointment', () => pm.expect(body.resourceType).to.eql('Appointment'));",
              "pm.test('Has id', () => pm.expect(body.id).to.be.a('string').and.not.empty);",
              "pm.test('Status is booked', () => pm.expect(body.status).to.eql('booked'));",
              "pm.test('Description matches', () => pm.expect(body.description).to.eql('Annual review'));",
              "pm.collectionVariables.set('appointmentId', body.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "POST Appointment — Past (fulfilled)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/appointments",
          "host": ["{{baseUrl}}"],
          "path": ["api", "appointments"]
        },
        "body": {
          "mode": "raw",
          "options": { "raw": { "language": "json" } },
          "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"start\": \"2026-01-10T10:00:00\",\n  \"end\": \"2026-01-10T10:30:00\",\n  \"description\": \"Follow-up visit\",\n  \"status\": \"fulfilled\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "",
              "const body = pm.response.json();",
              "pm.test('Status is fulfilled', () => pm.expect(body.status).to.eql('fulfilled'));",
              "pm.collectionVariables.set('appointmentId2', body.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "LIST Appointments for Patient",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/appointments?patientId={{patientId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "appointments"],
          "query": [{ "key": "patientId", "value": "{{patientId}}" }]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "",
              "const body = pm.response.json();",
              "pm.test('resourceType is Bundle', () => pm.expect(body.resourceType).to.eql('Bundle'));",
              "pm.test('Two appointments returned', () => pm.expect(body.entry.length).to.eql(2));",
              "",
              "const ids = body.entry.map(e => e.resource.id);",
              "pm.test('Both appointment IDs present', () => {",
              "  pm.expect(ids).to.include(pm.collectionVariables.get('appointmentId'));",
              "  pm.expect(ids).to.include(pm.collectionVariables.get('appointmentId2'));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Error — POST Appointment Missing patientId",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/appointments",
          "host": ["{{baseUrl}}"],
          "path": ["api", "appointments"]
        },
        "body": {
          "mode": "raw",
          "options": { "raw": { "language": "json" } },
          "raw": "{\n  \"start\": \"2026-07-15T09:00:00\",\n  \"end\": \"2026-07-15T09:30:00\",\n  \"status\": \"booked\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 400', () => pm.response.to.have.status(400));"
            ]
          }
        }
      ]
    },
    {
      "name": "Error — POST Appointment Missing start",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/appointments",
          "host": ["{{baseUrl}}"],
          "path": ["api", "appointments"]
        },
        "body": {
          "mode": "raw",
          "options": { "raw": { "language": "json" } },
          "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"end\": \"2026-07-15T09:30:00\",\n  \"status\": \"booked\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 400', () => pm.response.to.have.status(400));"
            ]
          }
        }
      ]
    },
    {
      "name": "Teardown — Cascade Delete Patient",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const pid = pm.collectionVariables.get('patientId');",
              "if (!pid) throw new Error('patientId is empty — teardown aborted');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Patient deleted', () => pm.expect(pm.response.code).to.be.oneOf([200, 204]));"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{fhirUrl}}/Patient/{{patientId}}?_cascade=delete",
          "host": ["{{fhirUrl}}"],
          "path": ["Patient", "{{patientId}}"],
          "query": [{ "key": "_cascade", "value": "delete" }]
        }
      }
    },
    {
      "name": "Teardown — Verify Patient Deleted",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/patients/{{patientId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "patients", "{{patientId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Patient gone (404 or 410)', () => pm.expect(pm.response.code).to.be.oneOf([404, 410]));"
            ]
          }
        }
      ]
    },
    {
      "name": "Teardown — Delete Practitioner",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Practitioner deleted', () => pm.expect(pm.response.code).to.be.oneOf([200, 204]));"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{fhirUrl}}/Practitioner/{{practitionerId}}",
          "host": ["{{fhirUrl}}"],
          "path": ["Practitioner", "{{practitionerId}}"]
        }
      }
    }
  ]
}
