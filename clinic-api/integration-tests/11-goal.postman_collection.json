{
  "info": {
    "name": "11 — Goal",
    "description": "GoalController — POST /api/goals, GET /api/goals?patientId.\n\nDependency: Patient only. Tests active goal with LOINC measure, completed (achieved) goal, and text-only goal without measure code.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "patientId", "value": "" },
    { "key": "goalId",    "value": "" },
    { "key": "goalId2",   "value": "" },
    { "key": "goalId3",   "value": "" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const token = pm.environment.get('BEARER_TOKEN');",
          "if (token) {",
          "  pm.request.headers.add({ key: 'Authorization', value: 'Bearer ' + token });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Setup — Create Patient",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/patients",
          "host": ["{{baseUrl}}"],
          "path": ["api", "patients"]
        },
        "body": {
          "mode": "raw",
          "options": { "raw": { "language": "json" } },
          "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"Goal\",\n  \"dateOfBirth\": \"1980-11-14\",\n  \"gender\": \"female\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.collectionVariables.set('patientId', pm.response.json().id);"
            ]
          }
        }
      ]
    },
    {
      "name": "POST Goal — Active with LOINC measure",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/goals",
          "host": ["{{baseUrl}}"],
          "path": ["api", "goals"]
        },
        "body": {
          "mode": "raw",
          "options": { "raw": { "language": "json" } },
          "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"description\": \"Reduce systolic BP below 130\",\n  \"status\": \"active\",\n  \"targetMeasureCode\": \"8480-6\",\n  \"targetMeasureDisplay\": \"Systolic blood pressure\",\n  \"targetValue\": 130.0,\n  \"targetUnit\": \"mm[Hg]\",\n  \"targetDate\": \"2026-09-01\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "",
              "const body = pm.response.json();",
              "pm.test('resourceType is Goal', () => pm.expect(body.resourceType).to.eql('Goal'));",
              "pm.test('Has id', () => pm.expect(body.id).to.be.a('string').and.not.empty);",
              "pm.test('lifecycleStatus is active', () => pm.expect(body.lifecycleStatus).to.eql('active'));",
              "pm.test('LOINC code is 8480-6', () => {",
              "  pm.expect(body.target[0].measure.coding[0].code).to.eql('8480-6');",
              "});",
              "pm.test('Target value is 130', () => {",
              "  pm.expect(body.target[0].detailQuantity.value).to.eql(130);",
              "});",
              "pm.test('Subject references patient', () => {",
              "  pm.expect(body.subject.reference).to.include(pm.collectionVariables.get('patientId'));",
              "});",
              "pm.collectionVariables.set('goalId', body.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "POST Goal — Completed (achieved)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/goals",
          "host": ["{{baseUrl}}"],
          "path": ["api", "goals"]
        },
        "body": {
          "mode": "raw",
          "options": { "raw": { "language": "json" } },
          "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"description\": \"Pain-free ambulation\",\n  \"status\": \"completed\",\n  \"targetMeasureCode\": \"55423-8\",\n  \"targetMeasureDisplay\": \"Steps per day\",\n  \"targetValue\": 7000.0,\n  \"targetUnit\": \"steps/day\",\n  \"targetDate\": \"2026-04-01\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "",
              "const body = pm.response.json();",
              "pm.test('lifecycleStatus is completed', () => pm.expect(body.lifecycleStatus).to.eql('completed'));",
              "pm.collectionVariables.set('goalId2', body.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "POST Goal — Text only (no LOINC measure)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/goals",
          "host": ["{{baseUrl}}"],
          "path": ["api", "goals"]
        },
        "body": {
          "mode": "raw",
          "options": { "raw": { "language": "json" } },
          "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"description\": \"Walk 30 minutes daily\",\n  \"status\": \"active\",\n  \"targetDate\": \"2026-08-01\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "",
              "const body = pm.response.json();",
              "pm.test('resourceType is Goal', () => pm.expect(body.resourceType).to.eql('Goal'));",
              "pm.test('lifecycleStatus is active', () => pm.expect(body.lifecycleStatus).to.eql('active'));",
              "pm.collectionVariables.set('goalId3', body.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "LIST Goals for Patient",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/goals?patientId={{patientId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "goals"],
          "query": [{ "key": "patientId", "value": "{{patientId}}" }]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "",
              "const body = pm.response.json();",
              "pm.test('resourceType is Bundle', () => pm.expect(body.resourceType).to.eql('Bundle'));",
              "pm.test('Three goals returned', () => pm.expect(body.entry.length).to.eql(3));",
              "",
              "const ids = body.entry.map(e => e.resource.id);",
              "pm.test('All goal IDs present', () => {",
              "  pm.expect(ids).to.include(pm.collectionVariables.get('goalId'));",
              "  pm.expect(ids).to.include(pm.collectionVariables.get('goalId2'));",
              "  pm.expect(ids).to.include(pm.collectionVariables.get('goalId3'));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Error — POST Goal Missing description",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/goals",
          "host": ["{{baseUrl}}"],
          "path": ["api", "goals"]
        },
        "body": {
          "mode": "raw",
          "options": { "raw": { "language": "json" } },
          "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"status\": \"active\",\n  \"targetDate\": \"2026-09-01\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 400', () => pm.response.to.have.status(400));"
            ]
          }
        }
      ]
    },
    {
      "name": "Teardown — Cascade Delete Patient",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const pid = pm.collectionVariables.get('patientId');",
              "if (!pid) throw new Error('patientId is empty — teardown aborted');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Patient deleted', () => pm.expect(pm.response.code).to.be.oneOf([200, 204]));"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{fhirUrl}}/Patient/{{patientId}}?_cascade=delete",
          "host": ["{{fhirUrl}}"],
          "path": ["Patient", "{{patientId}}"],
          "query": [{ "key": "_cascade", "value": "delete" }]
        }
      }
    },
    {
      "name": "Teardown — Verify Patient Deleted",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/patients/{{patientId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "patients", "{{patientId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Patient gone (404 or 410)', () => pm.expect(pm.response.code).to.be.oneOf([404, 410]));"
            ]
          }
        }
      ]
    }
  ]
}
