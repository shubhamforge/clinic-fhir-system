{
  "info": {
    "name": "09 — Diagnostic Report",
    "description": "DiagnosticReportController — POST /api/diagnostic-reports, GET /api/diagnostic-reports?patientId.\n\nKey side-effect: Creating a DiagnosticReport that references a ServiceRequest automatically sets the SR status to 'completed'.\n\nDependencies: Practitioner + Patient + Encounter + ServiceRequest (all created in Setup).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "practitionerId",    "value": "" },
    { "key": "patientId",         "value": "" },
    { "key": "encounterId",       "value": "" },
    { "key": "serviceRequestId",  "value": "" },
    { "key": "diagnosticReportId",  "value": "" },
    { "key": "diagnosticReportId2", "value": "" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const token = pm.environment.get('BEARER_TOKEN');",
          "if (token) {",
          "  pm.request.headers.add({ key: 'Authorization', value: 'Bearer ' + token });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Setup — Create Practitioner",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/practitioners",
          "host": ["{{baseUrl}}"],
          "path": ["api", "practitioners"]
        },
        "body": {
          "mode": "raw",
          "options": { "raw": { "language": "json" } },
          "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"Practitioner\",\n  \"specialty\": \"General Practice\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.collectionVariables.set('practitionerId', pm.response.json().id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Setup — Create Patient",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/patients",
          "host": ["{{baseUrl}}"],
          "path": ["api", "patients"]
        },
        "body": {
          "mode": "raw",
          "options": { "raw": { "language": "json" } },
          "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"DiagReport\",\n  \"dateOfBirth\": \"1972-04-18\",\n  \"gender\": \"female\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.collectionVariables.set('patientId', pm.response.json().id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Setup — Create Encounter",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/encounters",
          "host": ["{{baseUrl}}"],
          "path": ["api", "encounters"]
        },
        "body": {
          "mode": "raw",
          "options": { "raw": { "language": "json" } },
          "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"visitDate\": \"2026-04-10\",\n  \"reason\": \"Lab results visit\",\n  \"status\": \"finished\",\n  \"practitionerId\": \"{{practitionerId}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.collectionVariables.set('encounterId', pm.response.json().id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Setup — Create Service Request (active — will be auto-completed by DR)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/service-requests",
          "host": ["{{baseUrl}}"],
          "path": ["api", "service-requests"]
        },
        "body": {
          "mode": "raw",
          "options": { "raw": { "language": "json" } },
          "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"encounterId\": \"{{encounterId}}\",\n  \"practitionerId\": \"{{practitionerId}}\",\n  \"code\": \"Lipid Panel\",\n  \"category\": \"laboratory\",\n  \"status\": \"active\",\n  \"priority\": \"routine\",\n  \"authoredOn\": \"2026-04-10\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.test('SR starts as active', () => pm.expect(pm.response.json().status).to.eql('active'));",
              "pm.collectionVariables.set('serviceRequestId', pm.response.json().id);"
            ]
          }
        }
      ]
    },
    {
      "name": "POST Diagnostic Report (links to SR)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/diagnostic-reports",
          "host": ["{{baseUrl}}"],
          "path": ["api", "diagnostic-reports"]
        },
        "body": {
          "mode": "raw",
          "options": { "raw": { "language": "json" } },
          "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"encounterId\": \"{{encounterId}}\",\n  \"serviceRequestId\": \"{{serviceRequestId}}\",\n  \"title\": \"Lipid Panel\",\n  \"status\": \"final\",\n  \"issued\": \"2026-04-12\",\n  \"conclusion\": \"LDL 132 mg/dL — borderline elevated. Continue monitoring.\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "",
              "const body = pm.response.json();",
              "pm.test('resourceType is DiagnosticReport', () => pm.expect(body.resourceType).to.eql('DiagnosticReport'));",
              "pm.test('Has id', () => pm.expect(body.id).to.be.a('string').and.not.empty);",
              "pm.test('Status is final', () => pm.expect(body.status).to.eql('final'));",
              "pm.test('Conclusion matches', () => pm.expect(body.conclusion).to.include('LDL 132'));",
              "pm.test('Links to ServiceRequest', () => {",
              "  pm.expect(body.basedOn[0].reference).to.include(pm.collectionVariables.get('serviceRequestId'));",
              "});",
              "pm.collectionVariables.set('diagnosticReportId', body.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "GET Service Request — Verify Auto-Completed",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/service-requests/{{serviceRequestId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "service-requests", "{{serviceRequestId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "",
              "pm.test('SR auto-updated to completed when DR was created', () => {",
              "  pm.expect(pm.response.json().status).to.eql('completed');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "POST Diagnostic Report — Without SR (optional link)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/diagnostic-reports",
          "host": ["{{baseUrl}}"],
          "path": ["api", "diagnostic-reports"]
        },
        "body": {
          "mode": "raw",
          "options": { "raw": { "language": "json" } },
          "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"title\": \"Chest X-Ray\",\n  \"status\": \"final\",\n  \"issued\": \"2026-03-01\",\n  \"conclusion\": \"No acute findings.\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.test('DR created without SR link', () => {",
              "  const body = pm.response.json();",
              "  pm.expect(body.resourceType).to.eql('DiagnosticReport');",
              "});",
              "pm.collectionVariables.set('diagnosticReportId2', pm.response.json().id);"
            ]
          }
        }
      ]
    },
    {
      "name": "LIST Diagnostic Reports for Patient",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/diagnostic-reports?patientId={{patientId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "diagnostic-reports"],
          "query": [{ "key": "patientId", "value": "{{patientId}}" }]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "",
              "const body = pm.response.json();",
              "pm.test('resourceType is Bundle', () => pm.expect(body.resourceType).to.eql('Bundle'));",
              "pm.test('Two reports returned', () => pm.expect(body.entry.length).to.eql(2));"
            ]
          }
        }
      ]
    },
    {
      "name": "Error — POST Diagnostic Report Missing title",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/diagnostic-reports",
          "host": ["{{baseUrl}}"],
          "path": ["api", "diagnostic-reports"]
        },
        "body": {
          "mode": "raw",
          "options": { "raw": { "language": "json" } },
          "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"status\": \"final\",\n  \"issued\": \"2026-04-12\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 400', () => pm.response.to.have.status(400));"
            ]
          }
        }
      ]
    },
    {
      "name": "Error — POST Diagnostic Report Invalid serviceRequestId",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/diagnostic-reports",
          "host": ["{{baseUrl}}"],
          "path": ["api", "diagnostic-reports"]
        },
        "body": {
          "mode": "raw",
          "options": { "raw": { "language": "json" } },
          "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"serviceRequestId\": \"nonexistent-sr-abc\",\n  \"title\": \"Test Report\",\n  \"status\": \"final\",\n  \"issued\": \"2026-04-12\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 400 (invalid reference)', () => pm.response.to.have.status(400));"
            ]
          }
        }
      ]
    },
    {
      "name": "Teardown — Cascade Delete Patient",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const pid = pm.collectionVariables.get('patientId');",
              "if (!pid) throw new Error('patientId is empty — teardown aborted');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Patient deleted', () => pm.expect(pm.response.code).to.be.oneOf([200, 204]));"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{fhirUrl}}/Patient/{{patientId}}?_cascade=delete",
          "host": ["{{fhirUrl}}"],
          "path": ["Patient", "{{patientId}}"],
          "query": [{ "key": "_cascade", "value": "delete" }]
        }
      }
    },
    {
      "name": "Teardown — Verify Patient Deleted",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/patients/{{patientId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "patients", "{{patientId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Patient gone (404 or 410)', () => pm.expect(pm.response.code).to.be.oneOf([404, 410]));"
            ]
          }
        }
      ]
    },
    {
      "name": "Teardown — Delete Practitioner",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Practitioner deleted', () => pm.expect(pm.response.code).to.be.oneOf([200, 204]));"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{fhirUrl}}/Practitioner/{{practitionerId}}",
          "host": ["{{fhirUrl}}"],
          "path": ["Practitioner", "{{practitionerId}}"]
        }
      }
    }
  ]
}
