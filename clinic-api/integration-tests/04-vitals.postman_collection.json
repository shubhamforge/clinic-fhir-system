{
  "info": {
    "name": "04 — Vitals",
    "description": "VitalsController — POST /api/vitals, GET /api/vitals?patientId, GET /api/vitals?patientId&type.\n\nDependencies: Practitioner + Patient + Encounter. Tests all 6 vital types and all 4 type filters.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "practitionerId", "value": "" },
    { "key": "patientId",      "value": "" },
    { "key": "encounterId",    "value": "" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const token = pm.environment.get('BEARER_TOKEN');",
          "if (token) {",
          "  pm.request.headers.add({ key: 'Authorization', value: 'Bearer ' + token });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Setup — Create Practitioner",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/practitioners",
          "host": ["{{baseUrl}}"],
          "path": ["api", "practitioners"]
        },
        "body": {
          "mode": "raw",
          "options": { "raw": { "language": "json" } },
          "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"Practitioner\",\n  \"specialty\": \"General Practice\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.collectionVariables.set('practitionerId', pm.response.json().id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Setup — Create Patient",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/patients",
          "host": ["{{baseUrl}}"],
          "path": ["api", "patients"]
        },
        "body": {
          "mode": "raw",
          "options": { "raw": { "language": "json" } },
          "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"Vitals\",\n  \"dateOfBirth\": \"1980-11-05\",\n  \"gender\": \"female\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.collectionVariables.set('patientId', pm.response.json().id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Setup — Create Encounter",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/encounters",
          "host": ["{{baseUrl}}"],
          "path": ["api", "encounters"]
        },
        "body": {
          "mode": "raw",
          "options": { "raw": { "language": "json" } },
          "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"visitDate\": \"2026-04-15\",\n  \"reason\": \"Vitals check\",\n  \"status\": \"finished\",\n  \"practitionerId\": \"{{practitionerId}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.collectionVariables.set('encounterId', pm.response.json().id);"
            ]
          }
        }
      ]
    },
    {
      "name": "POST Vitals — Full Set (all 6 vitals)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/vitals",
          "host": ["{{baseUrl}}"],
          "path": ["api", "vitals"]
        },
        "body": {
          "mode": "raw",
          "options": { "raw": { "language": "json" } },
          "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"encounterId\": \"{{encounterId}}\",\n  \"effectiveDate\": \"2026-04-15\",\n  \"systolicBp\": 138,\n  \"diastolicBp\": 88,\n  \"weightKg\": 75.5,\n  \"spo2Percent\": 97,\n  \"heartRateBpm\": 72,\n  \"temperatureCelsius\": 36.7\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "",
              "const body = pm.response.json();",
              "pm.test('resourceType is Bundle', () => pm.expect(body.resourceType).to.eql('Bundle'));",
              "pm.test('Six observations created', () => pm.expect(body.entry.length).to.eql(6));",
              "",
              "const codes = body.entry.map(e => e.resource.code.coding[0].code);",
              "pm.test('All LOINC codes present', () => {",
              "  ['8480-6', '8462-4', '29463-7', '59408-5', '8867-4', '8310-5'].forEach(code => {",
              "    pm.expect(codes).to.include(code);",
              "  });",
              "});",
              "",
              "pm.test('All linked to encounter', () => {",
              "  body.entry.forEach(e => {",
              "    pm.expect(e.resource.encounter.reference).to.include(pm.collectionVariables.get('encounterId'));",
              "  });",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "POST Vitals — Partial (BP only)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/vitals",
          "host": ["{{baseUrl}}"],
          "path": ["api", "vitals"]
        },
        "body": {
          "mode": "raw",
          "options": { "raw": { "language": "json" } },
          "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"encounterId\": \"{{encounterId}}\",\n  \"effectiveDate\": \"2026-03-01\",\n  \"systolicBp\": 145,\n  \"diastolicBp\": 92\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "",
              "const body = pm.response.json();",
              "pm.test('Two observations created (BP pair)', () => pm.expect(body.entry.length).to.eql(2));",
              "",
              "const codes = body.entry.map(e => e.resource.code.coding[0].code);",
              "pm.test('Only BP LOINC codes', () => {",
              "  pm.expect(codes).to.include('8480-6');",
              "  pm.expect(codes).to.include('8462-4');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "GET All Vitals for Patient",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/vitals?patientId={{patientId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "vitals"],
          "query": [{ "key": "patientId", "value": "{{patientId}}" }]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "",
              "const body = pm.response.json();",
              "pm.test('resourceType is Bundle', () => pm.expect(body.resourceType).to.eql('Bundle'));",
              "pm.test('Eight observations total (6 full + 2 partial)', () => pm.expect(body.entry.length).to.eql(8));"
            ]
          }
        }
      ]
    },
    {
      "name": "GET Vitals — Filter systolic",
