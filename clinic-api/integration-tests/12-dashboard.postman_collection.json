    {
      "name": "Error — GET Dashboard Patient Not Found",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/dashboard/nonexistent-patient-99999",
          "host": ["{{baseUrl}}"],
          "path": ["api", "dashboard", "nonexistent-patient-99999"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 404', () => pm.response.to.have.status(404));",
              "",
              "const body = pm.response.json();",
              "pm.test('Error shape: status + message (not FHIR OperationOutcome)', () => {",
              "  pm.expect(body.status).to.eql(404);",
              "  pm.expect(body.message).to.be.a('string').and.not.empty;",
              "  pm.expect(body).to.not.have.property('resourceType');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Teardown — Cascade Delete Patient",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const pid = pm.collectionVariables.get('patientId');",
              "if (!pid) throw new Error('patientId is empty — teardown aborted');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Patient deleted', () => pm.expect(pm.response.code).to.be.oneOf([200, 204]));"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{fhirUrl}}/Patient/{{patientId}}?_cascade=delete",
          "host": ["{{fhirUrl}}"],
          "path": ["Patient", "{{patientId}}"],
          "query": [{ "key": "_cascade", "value": "delete" }]
        }
      }
    },
