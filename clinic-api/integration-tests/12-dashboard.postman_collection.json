    {
      "name": "GET Dashboard — Full Response",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/dashboard/{{patientId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "dashboard", "{{patientId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "",
              "const body = pm.response.json();",
              "",
              "// Patient identity",
              "pm.test('patient.id matches', () => pm.expect(body.patient.id).to.eql(pm.collectionVariables.get('patientId')));",
              "pm.test('careTeam is present', () => pm.expect(body.careTeam).to.be.an('object'));",
              "",
              "// Snapshot — latest vitals (from enc 3, systolic 141)",
              "pm.test('latestVitals.systolicBp.value is 141', () => {",
              "  pm.expect(body.snapshot.latestVitals.systolicBp.value).to.eql(141);",
              "});",
              "pm.test('latestVitals.systolicBp.flagged is true (141 > 140 warn)', () => {",
              "  pm.expect(body.snapshot.latestVitals.systolicBp.flagged).to.be.true;",
              "});",
              "pm.test('latestVitals.heartRate is present (seeded at enc 3)', () => {",
              "  pm.expect(body.snapshot.latestVitals.heartRate.value).to.eql(74);",
              "});",
              "pm.test('latestVitals.temperature is present (seeded at enc 3)', () => {",
              "  pm.expect(body.snapshot.latestVitals.temperature.value).to.eql(36.7);",
              "});",
              "",
              "// Alerts — systolic 141 triggers warning",
              "pm.test('alerts is array with at least 1 warning', () => {",
              "  pm.expect(body.snapshot.alerts).to.be.an('array');",
              "  pm.expect(body.snapshot.alerts.length).to.be.at.least(1);",
              "  const sevs = body.snapshot.alerts.map(a => a.severity);",
              "  pm.expect(sevs).to.include('warning');",
              "});",
              "",
              "// Snapshot — conditions and medications",
              "pm.test('activeConditions has at least 1 entry', () => pm.expect(body.snapshot.activeConditions.length).to.be.at.least(1));",
              "pm.test('currentMedications has 1 entry', () => pm.expect(body.snapshot.currentMedications.length).to.eql(1));",
              "",
              "// Care plan",
              "pm.test('activeCarePlan is non-null', () => pm.expect(body.activeCarePlan).to.not.be.null);",
              "pm.test('activeCarePlan.title matches', () => pm.expect(body.activeCarePlan.title).to.eql('Hypertension Management'));",
              "pm.test('activeCarePlan has 1 goal with progress', () => {",
              "  pm.expect(body.activeCarePlan.goals).to.be.an('array').with.lengthOf(1);",
              "  pm.expect(body.activeCarePlan.goals[0].progress).to.be.an('object');",
              "});",
              "",
              "// Pending orders",
              "pm.test('pendingServiceRequests has 1 entry (Lipid Panel)', () => {",
              "  pm.expect(body.pendingServiceRequests).to.be.an('array').with.lengthOf(1);",
              "  pm.expect(body.pendingServiceRequests[0].priority).to.eql('routine');",
              "});",
              "",
              "// Upcoming appointment",
              "pm.test('upcomingAppointment is non-null', () => pm.expect(body.upcomingAppointment).to.not.be.null);",
              "",
              "// warnings (partial-failure safe)",
              "pm.test('warnings is array', () => pm.expect(body.warnings).to.be.an('array'));"
            ]
          }
        }
      ]
